{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"rootDir": "src",
		"outDir": "dist"
	},
	"include": ["src"]
}
